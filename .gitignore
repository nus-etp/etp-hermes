.env
.env.*
!.env.example

*.log
*.lock
.DS_Store

.hermes/
.hermes-local/
.hermes-state.zip

# evals — local venv, pytest cache, and the editable-install egg-info
# that `uv pip install -e .[dev]` drops at the repo root
/.venv/
.pytest_cache/
__pycache__/
*.egg-info/

# preflight (scripts/preflight-feeds.py) outputs — derived state, GHA cache is source of truth
data/feed-cache.json
data/changed-sources.json

# jina-reader (scripts/jina-reader.py) outputs — derived state, GHA cache is source of truth
data/jina-items.json
data/jina-cache/

# per-run derived inputs for the layer prompts (collect-candidates.py, slice_companies.py)
data/candidates.json
data/agent-companies.json
data/touched-companies.json

# dead-feed detector machine output — derived from feed-cache.json each run;
# the committed human report is signals/feed-health.md
data/dead-feeds.json

# creative-baoyu-infographic skill working tree (intermediates only; the
# final PNG is copied into signals/briefs/<slug>/ by prompts/infographics.md)
/infographic/

# portfolio seed working files (scripts/_tmp_*.py + data/_*_seed.json)
/scripts/_tmp_*
/data/_block71_seed.json
/data/_grip_seed.json

# scripts/discover_portfolio.py output, regenerated per run
/data/portfolio-new-entries.json

# Static frontend (site/) — generated assets and dev-kit quarantine
site/node_modules
site/**/.next
site/**/.turbo
site/**/.cache
site/apps/web/out
site/apps/web/public/briefs
site/apps/web/src/data/*.generated.json
site/.trash
