# evals — local venv, pytest cache, and the editable-install egg-info
# that `uv pip install -e .[dev]` drops at the repo root
/.venv/
.pytest_cache/
__pycache__/
*.egg-info/

# preflight (scripts/preflight-feeds.py) outputs — derived state, GHA cache is source of truth
data/feed-cache.json
data/changed-sources.json

# creative-baoyu-infographic skill working tree (intermediates only; the
# final PNG is copied into signals/briefs/<slug>/ by prompts/infographics.md)
/infographic/

# block71 portfolio seed working files (scripts/_tmp_*.py + data/_block71_seed.json)
/scripts/_tmp_*
/data/_block71_seed.json

# Static frontend (site/) — generated assets and dev-kit quarantine
site/node_modules
site/**/.next
site/**/.turbo
site/**/.cache
site/apps/web/out
site/apps/web/public/briefs
site/apps/web/src/data/*.generated.json
site/.trash
